# Backend HTTP bind address.
# Use 127.0.0.1 for local host-only development, or 0.0.0.0 in containers.
APP_HOST=127.0.0.1
APP_PORT=3000

# Required for signing auth tokens. Replace in every real environment.
AUTH_SECRET=replace-with-a-long-random-secret

# Admin login password. Replace in every real environment.
ADMIN_PASSWORD=replace-with-a-secure-admin-password

# Access token lifetime, in seconds.
TOKEN_TTL_SECONDS=3600

# Directory for file-backed persistence. Mount this path to a persistent volume in production.
DATA_DIR=data

# Rust tracing filter.
RUST_LOG=backend=info
